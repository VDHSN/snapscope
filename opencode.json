{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "allow",
    "bash": {
      "*": "allow",
      "git push": "ask",
      "rm -rf": "ask",
      "sudo": "ask"
    },
    "webfetch": "allow"
  },

  "command": {
    "dev/plan": {
      "description": "Takes a github issue and produces a comprehensive implementation plan.",
      "template": "{file:.opencode/command/dev/plan.md}",
      "agent": "plan"
    },
    "git/commit": {
      "description": "Creates a new commit using conventional commit guidelines.",
      "template": "{file:.opencode/command/git/commit.md}",
      "agent": "build"
    },
    "git/prepare": {
      "description": "Prepares a new worktree for a github issue",
      "template": "{file:.opencode/command/git/prepare.md}",
      "agent": "build"
    }
  },
  "formatter": {
    "eslint": {
      "command": ["pnpm", "turbo", "run", "lint-fix", "--filter={package}"],
      "extensions": [".ts", ".tsx", ".js", ".jsx"],
      "environment": {
        "NODE_ENV": "development"
      }
    },
    "typescript": {
      "command": ["pnpm", "turbo", "run", "type-check", "--filter={package}"],
      "extensions": [".ts", ".tsx"],
      "environment": {
        "NODE_ENV": "development"
      }
    }
  },
  "instructions": ["AGENTS.md"],
  "mcp": {
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "vercel-snapscope": {
      "type": "remote",
      "url": "https://mcp.vercel.com/vdhsn/snapscope",
      "enabled": true
    },
    "puppeteer": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-puppeteer"],
      "enabled": true
    }
  }
}
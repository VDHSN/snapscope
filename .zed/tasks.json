[
  {
    "label": "Start Expo Dev Server",
    "command": "pnpm",
    "args": ["dev"],
    "cwd": "${ZED_WORKTREE_ROOT}",
    "env": {},
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always"
  },
  {
    "label": "Checks",
    "command": "pnpm",
    "args": ["checks"],
    "cwd": "${ZED_WORKTREE_ROOT}",
    "env": {},
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always"
  },
  {
    "label": "Claude",
    "command": "claude",
    "args": [
      "--model",
      "sonnet",
      "--permission-mode",
      "acceptEdits",
      "--dangerously-skip-permissions",
      "--mcp-config=.mcp.json",
      "--strict-mcp-config"
    ],
    "cwd": "${ZED_WORKTREE_ROOT}",
    "env": {},
    "use_new_terminal": true,
    "allow_concurrent_runs": true,
    "reveal": "always"
  }
]

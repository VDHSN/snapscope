{
  "permissions": {
    "allow": [
      "Bash(mkdir:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(pnpm:*)",
      "Bash(npx storybook@latest init:*)",
      "mcp__vercel-snapscope__list_projects",
      "mcp__vercel-snapscope__get_project",
      "mcp__vercel-snapscope__search_vercel_documentation",
      "mcp__context7"
    ],
    "deny": []
  },
  "enabledMcpjsonServers": ["notion", "context7", "vercel-snapscope"],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/eslint-hook.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/tsc-hook.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}

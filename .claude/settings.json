{
  "permissions": {
    "allow": [
      "Bash(mkdir:*)",
      "Bash(gh:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git status:*)",
      "Bash(git grep:*)",
      "Bash(git diff:*)",
      "Bash(pnpm:*)",
      "Bash(pnpx storybook@latest init:*)",
      "mcp__vercel-snapscope__list_projects",
      "mcp__vercel-snapscope__list_deployments",
      "mcp__vercel-snapscope__get_deployment",
      "mcp__context7",
      "mcp__memory"
    ],
    "deny": []
  },
  "enabledMcpjsonServers": ["notion", "context7", "vercel-snapscope", "memory"],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/eslint-hook.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/tsc-hook.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}

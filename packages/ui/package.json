{
  "name": "@snapscope/ui",
  "version": "0.0.1",
  "sideEffects": false,
  "license": "MIT",
  "scripts": {
    "build": "pnpm run build:components && pnpm run build:storybook",
    "build:components": "tsup src/button.tsx src/typography.tsx src/input.tsx src/vin-input.tsx src/badge.tsx src/card.tsx src/progress.tsx src/theme-toggle.tsx src/logo.tsx src/video-player.tsx src/assessment-card.tsx src/assessment-list.tsx src/feature-card.tsx src/icon.tsx src/camera-capture.tsx src/photo-preview-grid.tsx src/photo-position-card.tsx src/photo-progress-grid.tsx src/photo-guide-header.tsx src/photo-guide-types.ts src/types.ts --format esm,cjs --dts",
    "dev": "storybook dev -p 6006",
    "lint": "eslint src/**/*.{ts,tsx}",
    "lint-fix": "eslint src/**/*.{ts,tsx} --fix",
    "type-check": "tsc --noEmit",
    "storybook": "pnpm dev",
    "build:storybook": "storybook build"
  },
  "exports": {
    "./button": {
      "types": "./src/button.tsx",
      "import": "./dist/button.mjs",
      "require": "./dist/button.js"
    },
    "./typography": {
      "types": "./src/typography.tsx",
      "import": "./src/typography.tsx"
    },
    "./input": {
      "types": "./src/input.tsx",
      "import": "./src/input.tsx"
    },
    "./vin-input": {
      "types": "./src/vin-input.tsx",
      "import": "./src/vin-input.tsx"
    },
    "./badge": {
      "types": "./src/badge.tsx",
      "import": "./src/badge.tsx"
    },
    "./card": {
      "types": "./src/card.tsx",
      "import": "./src/card.tsx"
    },
    "./progress": {
      "types": "./src/progress.tsx",
      "import": "./src/progress.tsx"
    },
    "./theme-toggle": {
      "types": "./src/theme-toggle.tsx",
      "import": "./src/theme-toggle.tsx"
    },
    "./tokens": {
      "types": "./src/tokens/index.ts",
      "import": "./src/tokens/index.ts"
    },
    "./tokens/css": "./src/tokens/index.css",
    "./theme": {
      "types": "./src/tokens/theme.ts",
      "import": "./src/tokens/theme.ts"
    },
    "./logo": {
      "types": "./src/logo.tsx",
      "import": "./src/logo.tsx"
    },
    "./video-player": {
      "types": "./src/video-player.tsx",
      "import": "./src/video-player.tsx"
    },
    "./assessment-card": {
      "types": "./src/assessment-card.tsx",
      "import": "./src/assessment-card.tsx"
    },
    "./assessment-list": {
      "types": "./src/assessment-list.tsx",
      "import": "./src/assessment-list.tsx"
    },
    "./icon": {
      "types": "./src/icon.tsx",
      "import": "./src/icon.tsx"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts"
    },
    "./feature-card": {
      "types": "./src/feature-card.tsx",
      "import": "./src/feature-card.tsx"
    },
    "./camera-capture": {
      "types": "./src/camera-capture.tsx",
      "import": "./src/camera-capture.tsx"
    },
    "./photo-preview-grid": {
      "types": "./src/photo-preview-grid.tsx",
      "import": "./src/photo-preview-grid.tsx"
    },
    "./photo-position-card": {
      "types": "./src/photo-position-card.tsx",
      "import": "./src/photo-position-card.tsx"
    },
    "./photo-progress-grid": {
      "types": "./src/photo-progress-grid.tsx",
      "import": "./src/photo-progress-grid.tsx"
    },
    "./photo-guide-header": {
      "types": "./src/photo-guide-header.tsx",
      "import": "./src/photo-guide-header.tsx"
    },
    "./photo-guide-types": {
      "types": "./src/photo-guide-types.ts",
      "import": "./src/photo-guide-types.ts"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@storybook/test": "^8.6.14",
    "eslint": "^9",
    "storybook": "^8.6.14",
    "typescript": "^5",
    "typescript-eslint": "^8.38.0",
    "vite": "^5.4.11"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tsup": "^8.0.2",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19"
  },
  "publishConfig": {
    "access": "public"
  }
}

{
  "version": 2,
  "monorepo": true,
  "installCommand": "pnpm install",
  "buildCommand": "cd packages/client && pnpm run build",
  "outputDirectory": "packages/client/.next",
  "framework": "nextjs",
  "functions": {
    "packages/client/src/app/**/*.{js,ts,tsx}": {
      "runtime": "@vercel/node@3"
    }
  },
  "rewrites": [
    {
      "source": "/sw.js",
      "destination": "/packages/client/public/sw.js"
    },
    {
      "source": "/workbox-:hash.js",
      "destination": "/packages/client/public/workbox-:hash.js"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    },
    {
      "source": "/workbox-(.*).js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
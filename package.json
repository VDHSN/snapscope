{
  "version": "0.0.1",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "pnpm turbo build",
    "clean": "pnpm dev:clean",
    "dev": "pnpm turbo dev",
    "lint-fix": "pnpm turbo lint-fix",
    "design-system": "cd packages/ui && pnpm storybook",
    "claude": "claude --model sonnet --strict-mcp-config --mcp-config ./.mcp.json --ide",
    "checks": "pnpm turbo run build lint-fix type-check",
    "dev:start": "devpod up --open-ide=false .",
    "dev:connect": "ssh snapscope.devpod",
    "dev:clean": "devpod delete .",
    "dev:omnara": "uv run omnara"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@anthropic-ai/claude-code": "^1.0.89",
    "next": "15.5.0",
    "turbo": "^2.5.6"
  }
}

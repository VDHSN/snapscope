{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/*.stories.*",
        "!**/*.test.*",
        "!**/*.spec.*"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**",
        "storybook-static/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "lint": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/*.stories.*",
        "!**/dist/**",
        "!**/.next/**"
      ],
      "outputs": []
    },
    "lint-fix": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/*.stories.*",
        "!**/dist/**",
        "!**/.next/**"
      ],
      "outputs": [],
      "cache": false
    },
    "type-check": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/*.stories.*",
        "!**/*.test.*",
        "!**/*.spec.*"
      ],
      "outputs": [
        "**/*.tsbuildinfo"
      ]
    }
  }
}